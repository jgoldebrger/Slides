# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (deck AI, slide visuals/backgrounds, player TTS)
OPENAI_API_KEY=

# Inngest (background jobs — required in production)
# Local: use `npm run dev:all` (sets INNGEST_DEV=1; no keys needed)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Stripe (billing)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=

# Observability (optional)
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# E2E auth tests (optional, CI secrets)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
