{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "font": {
    "family": {
      "sans": {
        "$type": "fontFamily",
        "$value": ["var(--font-geist-sans)", "system-ui", "sans-serif"]
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["var(--font-geist-mono)", "ui-monospace", "monospace"]
      },
      "serif": {
        "$type": "fontFamily",
        "$value": ["Georgia", "Cambria", "Times New Roman", "serif"]
      }
    },
    "size": {
      "xs": { "$type": "dimension", "$value": "0.75rem", "$description": "12px" },
      "sm": { "$type": "dimension", "$value": "0.875rem", "$description": "14px" },
      "md": { "$type": "dimension", "$value": "1rem", "$description": "16px base" },
      "lg": { "$type": "dimension", "$value": "1.25rem", "$description": "20px Major Third" },
      "xl": { "$type": "dimension", "$value": "1.563rem", "$description": "25px" },
      "2xl": { "$type": "dimension", "$value": "1.953rem", "$description": "31px" },
      "3xl": { "$type": "dimension", "$value": "2.441rem", "$description": "39px" },
      "4xl": { "$type": "dimension", "$value": "3.052rem", "$description": "49px" }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 }
    },
    "lineHeight": {
      "tight": { "$type": "number", "$value": 1.15 },
      "snug": { "$type": "number", "$value": 1.35 },
      "normal": { "$type": "number", "$value": 1.5 }
    }
  },
  "textStyle": {
    "pageTitle": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "{font.size.xl}",
        "fontWeight": "{font.weight.semibold}",
        "lineHeight": "{font.lineHeight.tight}"
      }
    },
    "sectionHeading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "{font.size.md}",
        "fontWeight": "{font.weight.medium}",
        "lineHeight": "{font.lineHeight.snug}"
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "{font.size.sm}",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "{font.lineHeight.normal}"
      }
    },
    "helper": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontSize": "{font.size.sm}",
        "fontWeight": "{font.weight.regular}",
        "lineHeight": "{font.lineHeight.normal}"
      }
    }
  }
}
