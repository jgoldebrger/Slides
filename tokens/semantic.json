    "link": {
      "$type": "color",
      "$value": "{color.brand.600}"
    }
  },
  "surface": {
    "page": {
      "$type": "color",
      "$value": "{color.neutral.0}"
    },
    "card": {
      "$type": "color",
      "$value": "{color.neutral.0}"
    },
    "raised": {
      "$type": "color",
      "$value": "{color.brand.50}"
    },
    "muted": {
      "$type": "color",
      "$value": "{color.brand.50}"
    }
