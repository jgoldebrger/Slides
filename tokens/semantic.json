{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "action": {
    "primary": {
      "$type": "color",
      "$value": "{color.brand.600}"
    },
    "primary-hover": {
      "$type": "color",
      "$value": "{color.brand.700}"
    },
    "destructive": {
      "$type": "color",
      "$value": "{color.danger.600}"
    }
  },
  "text": {
    "primary": {
      "$type": "color",
      "$value": "{color.neutral.950}"
    },
    "secondary": {
      "$type": "color",
      "$value": "{color.neutral.500}"
    },
    "on-action": {
      "$type": "color",
      "$value": "{color.neutral.0}"
